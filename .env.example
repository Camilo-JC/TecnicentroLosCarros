# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS
# -----------------------------------------------------------------------------
# URL de conexión para la base de datos (por ejemplo, PostgreSQL o SQLite)
# Ejemplo para PostgreSQL: postgresql://usuario:contraseña@localhost:5432/tecnicentro?schema=public
# Ejemplo para SQLite: file:./dev.db
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/tecnicentro?schema=public"

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE AUTHENTICACIÓN (NEXTAUTH)
# -----------------------------------------------------------------------------
# Secreto para la encriptación de tokens JWT de NextAuth. 
# Puedes generar uno con el comando: openssl rand -base64 32
NEXTAUTH_SECRET="tu_secreto_super_seguro_aqui"

# URL base de la aplicación (usar http://localhost:3000 para desarrollo local)
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE NOTIFICACIONES (BREVO)
# -----------------------------------------------------------------------------
# Llave de la API de Brevo (SMTP/Transactional API) para el envío de correos.
# Puedes obtener una en app.brevo.com -> SMTP & API.
BREVO_API_KEY="tu_brevo_api_key_aqui"
